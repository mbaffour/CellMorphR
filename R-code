validate_data <- function(df) {
  required <- c("Condition", "Time_min", "Replicate")
  missing  <- setdiff(required, names(df))
  if (length(missing) > 0) {
    return(list(ok = FALSE,
                msg = paste("Missing required columns:", paste(missing, collapse = ", "),
                            "\n\nYour file must contain: Condition, Time_min, Replicate,",
                            "and at least one numeric measurement column (e.g., Area).")))
  }
  # Find numeric measurement columns (exclude metadata)
  meta_cols <- c("Condition", "Time_min", "Replicate", "Image", "Cell_ID")
  measure_cols <- setdiff(names(df), meta_cols)
  measure_cols <- measure_cols[sapply(df[measure_cols], is.numeric)]
  if (length(measure_cols) == 0) {
    return(list(ok = FALSE,
                msg = "No numeric measurement columns found beyond metadata columns."))
  }
  list(ok = TRUE, msg = "Data validated successfully.", measures = measure_cols)
}

compute_replicate_summaries <- function(df, measure) {
  df %>%
    group_by(Condition, Time_min, Replicate) %>%
    summarise(
      median_val = median(.data[[measure]], na.rm = TRUE),
      mean_val   = mean(.data[[measure]], na.rm = TRUE),
      sd_val     = sd(.data[[measure]], na.rm = TRUE),
      n_cells    = n(),
      q25        = quantile(.data[[measure]], 0.25, na.rm = TRUE),
      q75        = quantile(.data[[measure]], 0.75, na.rm = TRUE),
      .groups    = "drop"
    )
}

compute_condition_summaries <- function(rep_summary) {
  rep_summary %>%
    group_by(Condition, Time_min) %>%
    summarise(
      grand_median = mean(median_val),   # mean of per-replicate medians
      grand_mean   = mean(mean_val),     # mean of per-replicate means
      sem_median   = sd(median_val) / sqrt(n()),
      sem_mean     = sd(mean_val) / sqrt(n()),
      n_reps       = n(),
      .groups      = "drop"
    )
}

