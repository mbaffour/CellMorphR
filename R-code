server <- function(input, output, session) {

  # ---------------------------------------------------------------------------
  # HELPER: Save figures in multiple formats (PDF, PNG, SVG, TIFF, EPS)
  # ---------------------------------------------------------------------------
  save_figure <- function(file, plot_obj, width, height, dpi, format) {
    # TIFF: use LZW compression to keep file size reasonable
    if (format == "tiff") {
      ggsave(file, plot_obj, width = width, height = height,
             dpi = dpi, device = "tiff", compression = "lzw", bg = "white")
    # EPS: use cairo_ps device for better font embedding
    } else if (format == "eps") {
      ggsave(file, plot_obj, width = width, height = height,
             dpi = dpi, device = cairo_ps, bg = "white")
    # SVG: use svglite if available, otherwise base svg
    } else if (format == "svg") {
      if (requireNamespace("svglite", quietly = TRUE)) {
        ggsave(file, plot_obj, width = width, height = height,
               dpi = dpi, device = svglite::svglite)
      } else {
        ggsave(file, plot_obj, width = width, height = height,
               dpi = dpi, device = "svg")
      }
    # PNG: always white background
    } else if (format == "png") {
      ggsave(file, plot_obj, width = width, height = height,
             dpi = dpi, device = "png", bg = "white")
    # PDF: default
    } else {
      ggsave(file, plot_obj, width = width, height = height,
             dpi = dpi, device = "pdf")
    }
  }

  # Helper: get file extension string for downloadHandler filename
  fmt_ext <- function(format) {
    format  # format values already match extensions: pdf, png, svg, tiff, eps
  }

  # ---------------------------------------------------------------------------
  # REACTIVE: loaded data
  # ---------------------------------------------------------------------------
  raw_data <- reactiveVal(NULL)
  measure_cols <- reactiveVal(NULL)

  # File upload
  observeEvent(input$file, {
    req(input$file)
    ext <- tools::file_ext(input$file$name)
    df <- tryCatch({
      if (ext %in% c("xlsx", "xls")) {
        readxl::read_excel(input$file$datapath)
      } else if (ext == "csv") {
        read.csv(input$file$datapath, stringsAsFactors = FALSE)
      } else if (ext == "tsv") {
        read.delim(input$file$datapath, stringsAsFactors = FALSE)
      }
    }, error = function(e) NULL)

    if (is.null(df)) {
      showNotification("Failed to read file.", type = "error")
      return()
    }
    val <- validate_data(df)
    if (!val$ok) {
      showNotification(val$msg, type = "error", duration = 10)
      return()
    }
    # Ensure types
    df$Condition <- as.character(df$Condition)
    df$Time_min  <- as.numeric(df$Time_min)
    df$Replicate <- as.factor(df$Replicate)
    raw_data(df)
    measure_cols(val$measures)
    showNotification(paste("Loaded", nrow(df), "cells,", length(val$measures), "measures."),
                     type = "message")
  })

  # Demo data generator
  observeEvent(input$load_demo, {
    set.seed(42)
    conditions <- c("Uninfected", "+N4")
    times      <- c(30, 60, 90, 120)
    reps       <- 1:3
    rows <- list()
    for (cond in conditions) {
      for (tm in times) {
        for (rp in reps) {
          n_cells <- sample(180:220, 1)
          # Uninfected: stable ~3 µm² with slight growth
          # +N4: grows increasingly over time (lysis inhibition → filamentation)
          if (cond == "Uninfected") {
            base_area <- 3.0 + (tm - 30) * 0.002
            areas <- rlnorm(n_cells, log(base_area), 0.25)
          } else {
            base_area <- 3.0 + (tm - 30) * 0.025 + (tm / 120)^2 * 2
            areas <- rlnorm(n_cells, log(base_area), 0.3 + tm * 0.001)
          }
          # Add slight replicate effect
          areas <- areas * (1 + (rp - 2) * 0.03)
          perimeters <- 2 * sqrt(pi * areas) * runif(n_cells, 0.95, 1.15)
          rows[[length(rows) + 1]] <- data.frame(
            Condition = cond,
            Time_min  = tm,
            Replicate = rp,
            Area      = round(areas, 3),
