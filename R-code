      p <- ggplot(df, aes(x = .data[[m]], y = Group, fill = Condition)) +
        ggridges::geom_density_ridges(alpha = 0.7, scale = 1.3, linewidth = 0.3) +
        scale_fill_manual(values = cols) +
        labs(x = m, y = NULL, title = paste("Ridge Plot —", m))

    } else if (input$dist_type == "strip") {
      # Strip / jitter plot: all individual cells as points
      p <- ggplot(df, aes(x = Time_fac, y = .data[[m]], color = Condition)) +
        geom_point(position = position_jitterdodge(jitter.width = 0.2, dodge.width = 0.7),
                   size = 0.6, alpha = 0.15) +
        scale_color_manual(values = cols)
      if (input$show_rep_medians) {
        p <- p + stat_summary(aes(group = Condition), fun = median, geom = "crossbar",
                              position = position_dodge(0.7),
                              width = 0.3, linewidth = 0.5, color = "black", alpha = 0.7) +
          geom_point(data = rs,
                     aes(x = Time_fac, y = median_val, group = Condition),
                     position = position_dodge(0.7),
                     shape = 21, size = 3.5, fill = "white", color = "black", stroke = 0.8)
      }
      p <- p + labs(x = "Time Post-Infection", y = m,
                    title = paste("Single-Cell", m, "— Jitter Plot"),
                    subtitle = "Each point = one cell; crossbar = group median; circles = replicate medians (N=3)")

    } else if (input$dist_type == "sina") {
      # Sina plot: jitter width follows the density (like a violin made of points)
      # Uses ggforce::geom_sina if available, else fallback to density-scaled jitter
      if (requireNamespace("ggforce", quietly = TRUE)) {
        p <- ggplot(df, aes(x = Time_fac, y = .data[[m]], color = Condition)) +
          ggforce::geom_sina(position = position_dodge(0.8),
                             size = 0.5, alpha = 0.15, maxwidth = 0.35) +
          scale_color_manual(values = cols)
      } else {
        # Fallback: regular jitter if ggforce not installed
        p <- ggplot(df, aes(x = Time_fac, y = .data[[m]], color = Condition)) +
          geom_point(position = position_jitterdodge(jitter.width = 0.15, dodge.width = 0.8),
                     size = 0.5, alpha = 0.15) +
          scale_color_manual(values = cols)
      }
      if (input$show_rep_medians) {
        p <- p + geom_point(data = rs,
                            aes(x = Time_fac, y = median_val, group = Condition),
                            position = position_dodge(0.8),
                            shape = 21, size = 3.5, fill = "white", color = "black", stroke = 0.8)
      }
      p <- p + labs(x = "Time Post-Infection", y = m,
                    title = paste("Single-Cell", m, "— Sina Plot"),
                    subtitle = "Point spread follows density; circles = replicate medians (N=3)")

    } else if (input$dist_type == "dotplot") {
      # Dot plot: ONLY replicate-level summaries (what the stats are based on)
      p <- ggplot(rs, aes(x = Time_fac, y = median_val, color = Condition)) +
        geom_point(position = position_dodge(0.5),
                   size = 4, alpha = 0.85) +
        stat_summary(aes(group = Condition), fun = mean, geom = "crossbar",
                     position = position_dodge(0.5),
                     width = 0.3, linewidth = 0.5) +
        scale_color_manual(values = cols) +
        labs(x = "Time Post-Infection", y = paste("Median", m, "(per replicate)"),
             title = paste(m, "— Replicate Summary Dot Plot"),
             subtitle = "Each point = one biological replicate (N=3); crossbar = group mean")

    } else if (input$dist_type == "boxstrip") {
      p <- ggplot(df, aes(x = Time_fac, y = .data[[m]], fill = Condition)) +
        geom_boxplot(position = position_dodge(0.8), alpha = 0.6,
                     outlier.shape = NA, linewidth = 0.4) +
        scale_fill_manual(values = cols)
      if (input$show_rep_medians) {
        p <- p + geom_point(data = rs,
                            aes(x = Time_fac, y = median_val, group = Condition),
                            position = position_dodge(0.8),
                            shape = 18, size = 3.5, color = "black")
      }
      p <- p + labs(x = "Time Post-Infection", y = m,
                    title = paste("Box Plot —", m),
                    subtitle = "Diamonds = per-replicate medians")

    } else if (input$dist_type == "ecdf") {
      p <- ggplot(df, aes(x = .data[[m]], color = Condition)) +
        stat_ecdf(linewidth = 0.8) +
        scale_color_manual(values = cols) +
        facet_wrap(~ Time_fac, nrow = 1) +
        labs(x = m, y = "Cumulative Proportion",
             title = paste("Empirical CDF —", m),
             subtitle = "Rightward shift = larger cells")
    } else {
      # Fallback if ggridges not installed
      p <- ggplot(df, aes(x = Time_fac, y = .data[[m]], fill = Condition)) +
        geom_violin(position = position_dodge(0.8), alpha = 0.7) +
        scale_fill_manual(values = cols) +
        labs(x = "Time", y = m, title = paste(m, "Distributions"))
    }

    # --- Significance brackets ---
    # METHODOLOGY (documented for transparency):
    #   - Test: Welch's two-sample t-test (two-sided, unequal variance assumed)
    #   - Tested on: Per-replicate medians (the biological replicate is the
    #     statistical unit, NOT individual cells — see Lazic 2010)
    #   - N per group: Number of biological replicates (typically 3)
    #   - Correction: Holm-Bonferroni step-down across all time-point comparisons
    #   - Thresholds: * p<0.05, ** p<0.01, *** p<0.001 (APA convention)
    #   - This is identical to the pairwise tests in the Statistics tab when
    #     stat_summary = "median_val" (the default and recommended setting).
    
    bracket_types <- c("violin", "strip", "sina", "boxstrip", "dotplot")
    
    if (isTRUE(input$show_sig) && 
        input$dist_type %in% bracket_types &&
        length(unique(df$Condition)) >= 2) {
      
      # Use the user-specified reference condition (same as Statistics tab)
      ref_cond <- levels(df$Condition)[1]  # first level = reference (set in plot_data())
      trt_conds <- setdiff(levels(df$Condition), ref_cond)
      times_fac <- levels(df$Time_fac)
      
      # Determine dodge width to match the plot type's position_dodge()
      dodge_w <- switch(input$dist_type,
        "dotplot" = 0.5,
        "strip"   = 0.7,
        0.8  # violin, sina, boxstrip
      )
      
      # Get y-range for bracket positioning
      if (input$dist_type == "dotplot") {
        y_vals <- rs$median_val
      } else {
        y_vals <- df[[m]]
      }
      y_range <- diff(range(y_vals, na.rm = TRUE))
      if (y_range == 0) y_range <- 1
      
      # Collect p-values across ALL comparisons before correction
      # (Holm correction must see the full family of tests)
      sig_annot <- data.frame(
        Time_fac = character(), y_pos = numeric(), p_raw = numeric(),
        Treatment = character(), n_ctrl = integer(), n_trt = integer(),
        stringsAsFactors = FALSE
      )
      
      for (tf in times_fac) {
        tm <- as.numeric(gsub(" min", "", tf))
        for (trt in trt_conds) {
          ctrl_vals <- rs$median_val[rs$Condition == ref_cond & rs$Time_min == tm]
          trt_vals  <- rs$median_val[rs$Condition == trt & rs$Time_min == tm]
          
          if (length(ctrl_vals) >= 2 && length(trt_vals) >= 2) {
            tt <- tryCatch(
              t.test(trt_vals, ctrl_vals, var.equal = FALSE),
              error = function(e) NULL
            )
            if (!is.null(tt)) {
              if (input$dist_type == "dotplot") {
                y_top <- max(c(ctrl_vals, trt_vals), na.rm = TRUE)
              } else {
                y_top <- max(df[[m]][df$Time_min == tm], na.rm = TRUE)
              }
              sig_annot <- rbind(sig_annot, data.frame(
                Time_fac = tf, y_pos = y_top, p_raw = tt$p.value,
                Treatment = trt, n_ctrl = length(ctrl_vals), n_trt = length(trt_vals),
                stringsAsFactors = FALSE
              ))
            }
          }
        }
      }
      
      if (nrow(sig_annot) > 0) {
        # Holm-Bonferroni correction across the full family
        sig_annot$p_adj <- p.adjust(sig_annot$p_raw, method = "holm")
        sig_annot$stars <- ifelse(sig_annot$p_adj < 0.001, "***",
                            ifelse(sig_annot$p_adj < 0.01, "**",
                                   ifelse(sig_annot$p_adj < 0.05, "*", "ns")))
        
        # Format labels
        sig_annot$label <- switch(input$sig_label_style,
          "stars"   = sig_annot$stars,
          "stars_p" = ifelse(sig_annot$p_adj < 0.001,
                             paste0(sig_annot$stars, "\n(p<0.001)"),
                             paste0(sig_annot$stars, "\n(p=", formatC(sig_annot$p_adj, format = "f", digits = 3), ")")),
          "pval"    = ifelse(sig_annot$p_adj < 0.001, "p<0.001",
                             paste0("p=", formatC(sig_annot$p_adj, format = "f", digits = 3))),
          sig_annot$stars
        )
        
        # Optionally filter out ns brackets
        if (!isTRUE(input$show_ns)) {
          sig_annot <- sig_annot[sig_annot$stars != "ns", , drop = FALSE]
        }
        
        if (nrow(sig_annot) > 0) {
          # Bracket y-positioning: stagger if multiple comparisons at same timepoint
          bracket_base <- sig_annot$y_pos + y_range * 0.06
          bracket_step <- y_range * 0.10
          
          # For >2 conditions, stagger brackets at same timepoint
          for (tf in unique(sig_annot$Time_fac)) {
            idx <- which(sig_annot$Time_fac == tf)
            if (length(idx) > 1) {
              for (j in 2:length(idx)) {
                bracket_base[idx[j]] <- bracket_base[idx[j]] + (j - 1) * bracket_step
              }
            }
          }
          
          # position_dodge places k groups across dodge_w:
          # group i (0-indexed) is at: (i - (k-1)/2) * dodge_w / k from center
          n_levels <- length(levels(df$Condition))
          
          for (k in seq_len(nrow(sig_annot))) {
            x_center <- which(times_fac == sig_annot$Time_fac[k])
            
            # Compute the actual positions of control and treatment within dodge
            ref_idx <- 0  # reference is always first factor level
            trt_idx <- which(levels(df$Condition) == sig_annot$Treatment[k]) - 1  # 0-indexed
            
            if (n_levels == 2) {
              x_left  <- x_center - dodge_w / 4
              x_right <- x_center + dodge_w / 4
            } else {
              # General formula for position_dodge with n groups
              x_left  <- x_center + (ref_idx - (n_levels - 1) / 2) * dodge_w / n_levels
              x_right <- x_center + (trt_idx - (n_levels - 1) / 2) * dodge_w / n_levels
            }
            
            y_bar   <- bracket_base[k]
            y_tick  <- y_bar - y_range * 0.015
            
            # Determine color: gray for ns, black for significant
            bracket_color <- if (sig_annot$stars[k] == "ns") "grey60" else "black"
            label_color   <- if (sig_annot$stars[k] == "ns") "grey50" else "black"
            
            # Bracket: left tick, horizontal bar, right tick
            p <- p + annotate("segment", x = x_left, xend = x_left,
                              y = y_tick, yend = y_bar,
                              linewidth = 0.4, color = bracket_color) +
                     annotate("segment", x = x_left, xend = x_right,
                              y = y_bar, yend = y_bar,
                              linewidth = 0.4, color = bracket_color) +
                     annotate("segment", x = x_right, xend = x_right,
                              y = y_tick, yend = y_bar,
                              linewidth = 0.4, color = bracket_color) +
                     annotate("text", x = (x_left + x_right) / 2,
                              y = y_bar + y_range * 0.015,
                              label = sig_annot$label[k],
                              size = input$dist_base_size / 2.8,  # ~4.3pt at base 12 → legible
                              vjust = 0, color = label_color,
                              fontface = if (sig_annot$stars[k] != "ns") "bold" else "plain")
          }
          
          # Expand y-axis to fit all brackets + labels
          label_extra <- if (input$sig_label_style == "stars_p") 0.20 else 0.12
          max_bracket <- max(bracket_base) + y_range * label_extra
          p <- p + coord_cartesian(ylim = c(NA, max_bracket), clip = "off")
        }
        
        # Add annotation subtitle explaining the statistical test
        n_reps_range <- paste(range(c(sig_annot$n_ctrl, sig_annot$n_trt)), collapse = "–")
        n_comparisons <- nrow(sig_annot)
        p <- p + labs(caption = paste0(
          "Brackets: Welch's t-test on per-replicate medians (N = ",
          n_reps_range, " biological replicates/group), ",
          "Holm-corrected (", n_comparisons, " comparisons). ",
          "* p<0.05, ** p<0.01, *** p<0.001."
        ))
      }
    }

    p + theme_publication(input$dist_base_size)
  })

  output$dist_plot <- renderPlot({ dist_plot_obj() })
  output$dl_dist   <- downloadHandler(
    filename = function() paste0("distributions_", input$measure, ".", fmt_ext(input$dist_format)),
    content  = function(file) {
      save_figure(file, dist_plot_obj(), input$dist_width, input$dist_height,
                  input$dist_dpi, input$dist_format)
    }
  )

  # ---------------------------------------------------------------------------
  # TRAJECTORY TAB
  # ---------------------------------------------------------------------------
  traj_plot_obj <- reactive({
    req(rep_summ(), cond_summ(), input$traj_summary)
    rs <- rep_summ()
    cs <- cond_summ()
    cols <- cond_colors()
    yvar <- input$traj_summary
    ylab <- ifelse(yvar == "median_val",
                   paste("Median", input$measure, "per Replicate"),
