                             linewidth = 1.2, alpha = 0.15, span = 1)
      } else {
        # Fall back to linear trend with fewer time points
        p <- p + geom_smooth(data = rs,
                             aes(x = Time_min, y = .data[[yvar]], color = Condition),
                             method = "lm", se = input$traj_error && input$traj_style == "pointline",
                             linewidth = 1.2, alpha = 0.15)
      }
    }

    # Error bars (pointline style)
    if (input$traj_error && input$traj_style == "pointline" && !input$traj_smooth) {
      cs$yvar <- cs[[ifelse(yvar == "median_val", "grand_median", "grand_mean")]]
      cs$sem  <- cs[[ifelse(yvar == "median_val", "sem_median", "sem_mean")]]
      p <- p + geom_errorbar(data = cs,
                             aes(x = Time_min, ymin = yvar - sem, ymax = yvar + sem,
                                 color = Condition),
                             width = 3, linewidth = 0.6)
    }

    p + scale_color_manual(values = cols) +
      scale_x_continuous(breaks = sort(unique(rs$Time_min))) +
      labs(x = "Time Post-Infection (min)", y = ylab,
           title = paste(input$measure, "Trajectory Over Time"),
           subtitle = "Each point = one biological replicate; dashed lines connect replicates") +
      theme_publication(input$traj_base_size)
  })

  output$traj_plot <- renderPlot({ traj_plot_obj() })
  output$dl_traj   <- downloadHandler(
    filename = function() paste0("trajectory_", input$measure, ".", fmt_ext(input$traj_format)),
    content  = function(file) {
      save_figure(file, traj_plot_obj(), input$traj_width, input$traj_height,
                  input$traj_dpi, input$traj_format)
    }
  )

  # ---------------------------------------------------------------------------
  # STATISTICS TAB
  # ---------------------------------------------------------------------------
  stat_results <- reactiveVal(NULL)

  observeEvent(input$run_stats, {
    req(rep_summ(), input$stat_summary)
    rs  <- rep_summ()
    yvar <- input$stat_summary

    results <- list()

    # Descriptive summary
    desc <- rs %>%
      group_by(Condition, Time_min) %>%
      summarise(
        n_reps = n(),
        across(all_of(yvar), list(mean = mean, sd = sd, median = median)),
        .groups = "drop"
      )
    results$descriptive <- desc

    if (input$stat_method == "anova") {
      # Two-way ANOVA on replicate-level summaries
      rs$Time_fac <- factor(rs$Time_min)
      formula_str <- paste0(yvar, " ~ Condition * Time_fac")
      model <- aov(as.formula(formula_str), data = rs)
      anova_tbl <- summary(model)
      results$anova_summary <- anova_tbl
      results$model <- model
      results$method <- "Two-way ANOVA on per-replicate summaries"

      # --- Partial eta-squared ---
      ss_vals <- anova_tbl[[1]][["Sum Sq"]]
      ss_resid <- ss_vals[length(ss_vals)]
      eta2 <- ss_vals[-length(ss_vals)] / (ss_vals[-length(ss_vals)] + ss_resid)
      results$partial_eta2 <- data.frame(
        Source = rownames(anova_tbl[[1]])[-length(ss_vals)],
        partial_eta2 = round(eta2, 3)
      )

      # --- Assumption diagnostics ---
      resids <- residuals(model)
      # Shapiro-Wilk normality test on residuals
      sw <- tryCatch(shapiro.test(resids), error = function(e) NULL)
      results$shapiro <- sw
      # Levene's test (using median, via manual computation to avoid car dependency)
      rs$group <- interaction(rs$Condition, rs$Time_fac, drop = TRUE)
      group_medians <- tapply(rs[[yvar]], rs$group, median)
      rs$abs_dev <- abs(rs[[yvar]] - group_medians[rs$group])
      levene_model <- tryCatch({
        summary(aov(abs_dev ~ group, data = rs))
      }, error = function(e) NULL)
      results$levene <- levene_model

      # Pairwise: Welch's t-test at each time point with 95% CIs
      cond_levels <- levels(rs$Condition)
      ref_cond <- cond_levels[1]
      trt_conds <- cond_levels[-1]

      pw_list <- lapply(sort(unique(rs$Time_min)), function(tm) {
        rs_t <- rs[rs$Time_min == tm, ]
        lapply(trt_conds, function(trt) {
          ctrl_vals <- rs_t[[yvar]][rs_t$Condition == ref_cond]
          trt_vals  <- rs_t[[yvar]][rs_t$Condition == trt]
          # Welch's t-test: var.equal=FALSE is R's default
          tt <- tryCatch(t.test(trt_vals, ctrl_vals, var.equal = FALSE, conf.level = 0.95),
                         error = function(e) NULL)
          data.frame(
            Time_min  = tm,
            Control   = ref_cond,
            Treatment = trt,
            ctrl_mean = mean(ctrl_vals, na.rm = TRUE),
            trt_mean  = mean(trt_vals, na.rm = TRUE),
            diff      = mean(trt_vals, na.rm = TRUE) - mean(ctrl_vals, na.rm = TRUE),
            CI_lo     = if (!is.null(tt)) tt$conf.int[1] else NA_real_,
            CI_hi     = if (!is.null(tt)) tt$conf.int[2] else NA_real_,
            t_stat    = if (!is.null(tt)) tt$statistic else NA_real_,
            df        = if (!is.null(tt)) tt$parameter else NA_real_,
            p_raw     = if (!is.null(tt)) tt$p.value else NA_real_,
            stringsAsFactors = FALSE
          )
        }) %>% bind_rows()
      }) %>% bind_rows()
      pw_list$p_adj <- p.adjust(pw_list$p_raw, method = "holm")
      pw_list$sig   <- ifelse(pw_list$p_adj < 0.001, "***",
                         ifelse(pw_list$p_adj < 0.01, "**",
                                ifelse(pw_list$p_adj < 0.05, "*", "ns")))
      results$pairwise <- pw_list

    } else if (input$stat_method == "lmm" && has_lme4) {
      # Linear mixed model on ALL cell-level data
      # This is the sophisticated approach: cell-level data with replicate as random effect
      req(plot_data(), input$measure)
      df <- plot_data()
      df$Time_fac <- factor(df$Time_min)

      # CRITICAL: Create unique replicate IDs across conditions.
      # Replicate "1" in Uninfected is a DIFFERENT dish than Replicate "1" in +N4.
      # Without this, lmer treats them as the same random-effect group.
      df$Rep_unique <- interaction(df$Condition, df$Replicate, drop = TRUE)

      formula_lmm <- as.formula(paste0(input$measure, " ~ Condition * Time_fac + (1|Rep_unique)"))

      model <- tryCatch({
        # lmerTest::lmer gives anova() with p-values via Satterthwaite approximation
        if (requireNamespace("lmerTest", quietly = TRUE)) {
          lmerTest::lmer(formula_lmm, data = df)
        } else {
          lme4::lmer(formula_lmm, data = df)
        }
      }, error = function(e) {
        showNotification(paste("LMM failed:", e$message), type = "error", duration = 10)
        return(NULL)
      })

      if (!is.null(model)) {
        results$model <- model
        results$anova_summary <- tryCatch(anova(model), error = function(e) NULL)
        results$method <- "Linear Mixed Model (cell-level with replicate as random effect)"

        if (has_emmeans) {
          emm <- tryCatch(emmeans::emmeans(model, ~ Condition | Time_fac), error = function(e) NULL)
          if (!is.null(emm)) {
            pw  <- pairs(emm, adjust = "holm")
            results$emmeans  <- emm
            results$pairwise_emm <- pw
          }
        }
      }
    }

    stat_results(results)
    showNotification("Analysis complete.", type = "message")
  })

  output$stat_output <- renderPrint({
    req(stat_results())
    r <- stat_results()
    cat("=== METHOD ===\n")
    cat(r$method, "\n\n")
    cat("=== ANOVA TABLE ===\n")
    if (!is.null(r$anova_summary)) {
      print(r$anova_summary)
      if (!has_lmerTest && grepl("Mixed", r$method)) {
        cat("\nNote: Install the 'lmerTest' package for p-values in the ANOVA table.\n")
        cat("  install.packages('lmerTest')\n")
      }
    } else {
      cat("ANOVA table not available.\n")
    }

    # Partial eta-squared
    if (!is.null(r$partial_eta2)) {
      cat("\n=== EFFECT SIZES (partial eta-squared) ===\n")
      cat("Benchmarks: small = 0.01, medium = 0.06, large = 0.14 (Cohen, 1988)\n")
      print(r$partial_eta2, row.names = FALSE)
    }

    cat("\nKey: Look at the Condition:Time interaction term.\n")
    cat("A significant interaction (p < 0.05) means the infection effect\n")
    cat("changes over time.\n\n")

    # Assumption diagnostics
    if (!is.null(r$shapiro) || !is.null(r$levene)) {
      cat("=== ANOVA ASSUMPTION DIAGNOSTICS ===\n")
    }
    if (!is.null(r$shapiro)) {
      cat(sprintf("  Shapiro-Wilk (normality of residuals): W = %.4f, p = %.4f\n",
                  r$shapiro$statistic, r$shapiro$p.value))
      if (r$shapiro$p.value >= 0.05) {
        cat("    --> Residuals consistent with normality.\n")
      } else {
        cat("    --> Residuals deviate from normality.\n")
        cat("       ANOVA is robust with balanced designs.\n")
      }
    }
    if (!is.null(r$levene)) {
      lev_f <- r$levene[[1]]["group", "F value"]
      lev_p <- r$levene[[1]]["group", "Pr(>F)"]
      cat(sprintf("  Levene's test (homogeneity of variance): F = %.4f, p = %.4f\n",
                  lev_f, lev_p))
      if (lev_p >= 0.05) {
        cat("    --> Variances homogeneous across groups.\n")
      } else {
        cat("    --> Variances differ across groups.\n")
        cat("       ANOVA is fairly robust with balanced designs.\n")
      }
    }
    cat("\n")

    if (!is.null(r$pairwise)) {
      cat("=== PAIRWISE COMPARISONS (Welch's t-test, 95% CI, Holm-corrected) ===\n")
    }
    if (!is.null(r$pairwise_emm)) {
      cat("=== PAIRWISE COMPARISONS (emmeans) ===\n")
      print(r$pairwise_emm)
    }
  })

  output$pairwise_table <- renderDT({
    req(stat_results())
    r <- stat_results()
    if (!is.null(r$pairwise)) {
      pw <- r$pairwise
      pw[] <- lapply(pw, function(x) if (is.numeric(x)) round(x, 4) else x)
      datatable(pw, options = list(pageLength = 10, dom = 't'))
    } else if (!is.null(r$pairwise_emm)) {
      datatable(as.data.frame(summary(r$pairwise_emm)),
                options = list(pageLength = 10, dom = 't'))
    }
  })

  output$dl_stats <- downloadHandler(
    filename = function() paste0("stats_results_", input$measure, "_", Sys.Date(), ".txt"),
    content  = function(file) {
      r <- stat_results()
      sink(file)
      cat("================================================================\n")
      cat("CellMorphR Statistical Results\n")
      cat("================================================================\n")
      cat("Date:", as.character(Sys.time()), "\n")
      cat("Measure:", input$measure, "\n")
      cat("Method:", r$method, "\n\n")

      if (!is.null(r$descriptive)) {
        cat("=== DESCRIPTIVE STATISTICS (per-replicate summaries) ===\n")
        print(as.data.frame(r$descriptive), row.names = FALSE)
        cat("\n")
      }

      cat("=== ANOVA TABLE ===\n")
      if (!is.null(r$anova_summary)) {
        print(r$anova_summary)
      } else {
        cat("ANOVA table not available.\n")
      }

      if (!is.null(r$partial_eta2)) {
        cat("\n=== EFFECT SIZES (partial eta-squared) ===\n")
        cat("Benchmarks: small=0.01, medium=0.06, large=0.14 (Cohen, 1988)\n")
        print(r$partial_eta2, row.names = FALSE)
      }

      cat("\n=== ASSUMPTION DIAGNOSTICS ===\n")
      if (!is.null(r$shapiro)) {
        cat(sprintf("Shapiro-Wilk (normality): W = %.4f, p = %.4f\n",
                    r$shapiro$statistic, r$shapiro$p.value))
      }
      if (!is.null(r$levene)) {
        lev_f <- r$levene[[1]]["group", "F value"]
        lev_p <- r$levene[[1]]["group", "Pr(>F)"]
        cat(sprintf("Levene's test (homogeneity): F = %.4f, p = %.4f\n", lev_f, lev_p))
      }

      if (!is.null(r$pairwise)) {
        cat("\n=== PAIRWISE COMPARISONS (Welch's t-test, 95% CI, Holm-corrected) ===\n")
        print(as.data.frame(r$pairwise), row.names = FALSE)
      }

      if (!is.null(r$pairwise_emm)) {
        cat("\n=== PAIRWISE COMPARISONS (emmeans, Holm-corrected) ===\n")
        print(r$pairwise_emm)
      }

      cat("\n================================================================\n")
      cat("STATISTICAL METHODS\n")
      cat("================================================================\n")
      cat("ANOVA: Two-way factorial ANOVA (Type I SS) on per-replicate\n")
      cat("summaries. Effect sizes: partial eta-squared (Cohen, 1988).\n")
      cat("With balanced design, Type I = Type II = Type III SS.\n\n")
      cat("Assumption diagnostics:\n")
      cat("  - Shapiro-Wilk test for normality of residuals\n")
      cat("  - Levene's test (median-centered) for homogeneity of variance\n")
      cat("  ANOVA robust to moderate violations (Maxwell & Delaney, 2004)\n\n")
      cat("Pairwise: Welch's t-test (Ruxton, 2006) with 95% CIs.\n")
      cat("Correction: Holm-Bonferroni step-down (Holm, 1979).\n\n")
      cat("Statistical unit: Biological replicate, not individual cell.\n")
      cat("This avoids pseudoreplication (Lazic, 2010).\n\n")
      cat("Both R Shiny and Python CellMorphR produce identical results.\n")
      cat("================================================================\n")
      sink()
    }
  )

  # ---------------------------------------------------------------------------
  # EFFECT SIZES TAB
  # ---------------------------------------------------------------------------
  es_data <- reactive({
    req(rep_summ(), input$es_summary, input$ref_condition)
    rs   <- rep_summ()
    yvar <- input$es_summary
    ref  <- input$ref_condition
    conds <- setdiff(levels(rs$Condition), ref)
    if (length(conds) == 0) conds <- setdiff(unique(as.character(rs$Condition)), ref)

    times <- sort(unique(rs$Time_min))
    es_list <- lapply(times, function(tm) {
      ctrl_vals <- rs[[yvar]][rs$Condition == ref & rs$Time_min == tm]
      lapply(conds, function(cd) {
        trt_vals <- rs[[yvar]][rs$Condition == cd & rs$Time_min == tm]
        ctrl_m <- mean(ctrl_vals)
        trt_m  <- mean(trt_vals)
        pooled_sd <- sqrt((var(ctrl_vals) + var(trt_vals)) / 2)
        data.frame(
          Time_min  = tm,
          Condition = cd,
          ctrl_mean = ctrl_m,
          trt_mean  = trt_m,
          abs_diff  = trt_m - ctrl_m,
          pct_change = if (abs(ctrl_m) > 1e-10) (trt_m - ctrl_m) / ctrl_m * 100 else NA_real_,
          cohens_d  = if (pooled_sd > 0) (trt_m - ctrl_m) / pooled_sd else NA_real_
        )
      }) %>% bind_rows()
    }) %>% bind_rows()
    es_list
  })

  es_plot_obj <- reactive({
    req(es_data(), input$es_type)
    esd  <- es_data()
    cols <- cond_colors()
    yvar <- input$es_type
    ylab <- switch(yvar,
                   abs_diff   = paste("Δ", input$measure, "(Treatment - Control)"),
                   pct_change = paste("% Change in", input$measure),
                   cohens_d   = "Cohen's d")

    p <- ggplot(esd, aes(x = Time_min, y = .data[[yvar]], color = Condition)) +
      geom_hline(yintercept = 0, linetype = "dashed", color = "grey50") +
      geom_line(linewidth = 1.2) +
      geom_point(size = 4) +
      scale_color_manual(values = cols[-1]) +
      scale_x_continuous(breaks = sort(unique(esd$Time_min))) +
      labs(x = "Time Post-Infection (min)", y = ylab,
           title = paste("Effect of Infection on", input$measure, "Over Time"),
           subtitle = "Computed from per-replicate summary means") +
      theme_publication(input$es_base_size)

    if (yvar == "cohens_d") {
      p <- p + geom_hline(yintercept = c(-0.8, 0.8), linetype = "dotted", color = "grey70") +
        annotate("text", x = min(esd$Time_min), y = 0.85, label = "Large effect (|d|=0.8)",
                 hjust = 0, size = 3, color = "grey50")
    }
    p
  })

  output$es_plot  <- renderPlot({ es_plot_obj() })
  output$es_table <- renderDT({
    req(es_data())
    esd <- es_data()
    esd[] <- lapply(esd, function(x) if (is.numeric(x)) round(x, 3) else x)
    datatable(esd, options = list(dom = 't'))
  })
  output$dl_es <- downloadHandler(
    filename = function() paste0("effect_sizes_", input$measure, ".", fmt_ext(input$es_format)),
    content  = function(file) {
      save_figure(file, es_plot_obj(), input$es_width, input$es_height,
                  input$es_dpi, input$es_format)
    }
  )

  # ---------------------------------------------------------------------------
  # PUBLICATION COMPOSITE FIGURE
  # ---------------------------------------------------------------------------
  pub_plot_obj <- reactive({
    req(input$pub_panels, has_patchwork)
    panels <- list()

    base <- input$pub_base_size
    df   <- plot_data()
    rs   <- rep_summ()
    cols <- cond_colors()
    m    <- input$measure

    if ("dist" %in% input$pub_panels) {
      df$Time_fac <- factor(paste0(df$Time_min, " min"),
                            levels = paste0(sort(unique(df$Time_min)), " min"))
      rs$Time_fac <- factor(paste0(rs$Time_min, " min"),
                            levels = paste0(sort(unique(rs$Time_min)), " min"))
      p_dist <- ggplot(df, aes(x = Time_fac, y = .data[[m]], fill = Condition)) +
        geom_violin(position = position_dodge(0.8), alpha = 0.7,
                    scale = "width", linewidth = 0.3, color = "grey30") +
        geom_point(data = rs,
                   aes(x = Time_fac, y = median_val, fill = Condition, group = Condition),
                   position = position_dodge(0.8),
                   shape = 21, size = 2.5, color = "black", stroke = 0.7) +
        scale_fill_manual(values = cols) +
        labs(x = NULL, y = m, title = NULL) +
        theme_publication(base) +
        theme(legend.position = "none")
      panels[["dist"]] <- p_dist
    }

    if ("traj" %in% input$pub_panels) {
      yvar <- "median_val"
      p_traj <- ggplot(rs, aes(x = Time_min, y = .data[[yvar]], color = Condition)) +
        geom_line(aes(group = interaction(Condition, Replicate)),
                  alpha = 0.35, linewidth = 0.4, linetype = "dashed") +
        geom_point(aes(shape = Replicate), size = 2.5, alpha = 0.8) +
        scale_color_manual(values = cols) +
        scale_x_continuous(breaks = sort(unique(rs$Time_min))) +
        labs(x = "Time (min)", y = paste("Median", m), title = NULL) +
        theme_publication(base)
      # Add loess only if enough time points (loess needs >= 4)
      if (length(unique(rs$Time_min)) >= 4) {
        p_traj <- p_traj +
          geom_smooth(method = "loess", se = TRUE, alpha = 0.12,
                      linewidth = 1.1, span = 1)
      } else {
        p_traj <- p_traj +
          stat_summary(fun = mean, geom = "line", linewidth = 1.1)
      }
      panels[["traj"]] <- p_traj
    }

    if ("effect" %in% input$pub_panels) {
      esd <- es_data()
      p_es <- ggplot(esd, aes(x = Time_min, y = pct_change, color = Condition)) +
        geom_hline(yintercept = 0, linetype = "dashed", color = "grey50") +
        geom_line(linewidth = 1.1) + geom_point(size = 3.5) +
        scale_color_manual(values = cols[-1]) +
        scale_x_continuous(breaks = sort(unique(esd$Time_min))) +
        labs(x = "Time (min)", y = paste("% Δ", m), title = NULL) +
        theme_publication(base) +
        theme(legend.position = "none")
      panels[["effect"]] <- p_es
    }

    if (length(panels) == 0) return(NULL)

    # Add panel labels
    labeled <- lapply(seq_along(panels), function(i) {
      panels[[i]] + ggtitle(LETTERS[i])
    })

    patchwork::wrap_plots(labeled, nrow = 1) +
      patchwork::plot_annotation(
        title    = paste(m, "— Bacteriophage Infection Time Course"),
        subtitle = "Per-replicate analysis (N=3 biological replicates per group)",
        theme    = theme_publication(base)
      )
  })

  output$pub_plot <- renderPlot({
    if (has_patchwork) pub_plot_obj()
  })

  output$dl_pub <- downloadHandler(
    filename = function() paste0("figure_", input$measure, ".", fmt_ext(input$pub_format)),
    content  = function(file) {
      save_figure(file, pub_plot_obj(), input$pub_width, input$pub_height,
                  input$pub_dpi, input$pub_format)
    }
  )
}

