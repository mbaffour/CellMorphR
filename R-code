  # ---------------------------------------------------------------------------
  # DISTRIBUTIONS TAB
  # ---------------------------------------------------------------------------
  dist_plot_obj <- reactive({
    req(plot_data(), input$measure, input$dist_type)
    df  <- plot_data()
    m   <- input$measure
    rs  <- rep_summ()
    cols <- cond_colors()

    # Factor time for discrete x-axis
    df$Time_fac <- factor(paste0(df$Time_min, " min"),
                          levels = paste0(sort(unique(df$Time_min)), " min"))
    rs$Time_fac <- factor(paste0(rs$Time_min, " min"),
                          levels = paste0(sort(unique(rs$Time_min)), " min"))

    if (input$dist_type == "violin") {
      p <- ggplot(df, aes(x = Time_fac, y = .data[[m]], fill = Condition)) +
        geom_violin(position = position_dodge(0.8), alpha = 0.7,
                    scale = "width", linewidth = 0.3, color = "grey30") +
        scale_fill_manual(values = cols)

      if (input$show_cell_points) {
        p <- p + geom_point(position = position_jitterdodge(
          jitter.width = 0.15, dodge.width = 0.8),
          size = 0.3, alpha = input$point_alpha, color = "grey30")
      }
      if (input$show_rep_medians) {
        p <- p + geom_point(data = rs,
                            aes(x = Time_fac, y = median_val, fill = Condition, group = Condition),
                            position = position_dodge(0.8),
                            shape = 21, size = 3.5, color = "black", stroke = 0.8) +
          geom_point(data = rs,
                     aes(x = Time_fac, y = median_val, fill = Condition, group = Condition),
                     position = position_dodge(0.8),
                     shape = 21, size = 3.5, color = "black", stroke = 0.0, alpha = 0.8)
      }
      p <- p + labs(x = "Time Post-Infection", y = m,
                    title = paste("Single-Cell", m, "Distributions"),
                    subtitle = "Violins = cell distributions; points = per-replicate medians (N=3)")

    } else if (input$dist_type == "ridge" && has_ridges) {
      df$Group <- interaction(df$Condition, df$Time_fac, sep = " | ")
      # Order: by time then condition (reversed for top-to-bottom)
      group_levels <- rev(as.character(
        interaction(
          rep(levels(df$Condition), length(levels(df$Time_fac))),
          rep(levels(df$Time_fac), each = length(levels(df$Condition))),
          sep = " | "
        )
      ))
